(footprint "Micro_USB_Converter"
	(layer "F.Cu")
	(descr "Micro USB Converter Breakout 14x12mm")
	(attr through_hole)
	(fp_text reference "REF**" (at 0 -7.5) (layer "F.SilkS")
		(effects (font (size 1 1) (thickness 0.15)))
	)
	(fp_text value "Micro_USB_Converter" (at 0 7.5) (layer "F.Fab")
		(effects (font (size 1 1) (thickness 0.15)))
	)
	(fp_line (start -7 -6) (end 7 -6) (stroke (width 0.12) (type solid)) (layer "F.SilkS"))
	(fp_line (start 7 -6) (end 7 6) (stroke (width 0.12) (type solid)) (layer "F.SilkS"))
	(fp_line (start 7 6) (end -7 6) (stroke (width 0.12) (type solid)) (layer "F.SilkS"))
	(fp_line (start -7 6) (end -7 -6) (stroke (width 0.12) (type solid)) (layer "F.SilkS"))
	(fp_rect (start -7.25 -6.25) (end 7.25 6.25) (stroke (width 0.05) (type solid)) (fill no) (layer "F.CrtYd"))
	(fp_text user "USB" (at -4 0 90) (layer "F.SilkS")
		(effects (font (size 1 1) (thickness 0.15)))
	)
	(pad "1" thru_hole rect (at 5.73 -5.08) (size 1.7 1.7) (drill 1) (layers "*.Cu" "*.Mask")
		(net 0 "") (pinfunction "VCC") (pintype "power_out")
	)
	(pad "2" thru_hole circle (at 5.73 -2.54) (size 1.7 1.7) (drill 1) (layers "*.Cu" "*.Mask")
		(net 0 "") (pinfunction "D-") (pintype "bidirectional")
	)
	(pad "3" thru_hole circle (at 5.73 0) (size 1.7 1.7) (drill 1) (layers "*.Cu" "*.Mask")
		(net 0 "") (pinfunction "D+") (pintype "bidirectional")
	)
	(pad "4" thru_hole circle (at 5.73 2.54) (size 1.7 1.7) (drill 1) (layers "*.Cu" "*.Mask")
		(net 0 "") (pinfunction "ID") (pintype "bidirectional")
	)
	(pad "5" thru_hole circle (at 5.73 5.08) (size 1.7 1.7) (drill 1) (layers "*.Cu" "*.Mask")
		(net 0 "") (pinfunction "GND") (pintype "power_out")
	)
	(model "${KICAD6_3DMODEL_DIR}/Connector_USB.3dshapes/USB_Micro-B_Molex_47346-0001.step"
		(offset (xyz -6 0 0))
		(scale (xyz 1 1 1))
		(rotate (xyz 0 0 90))
	)
)